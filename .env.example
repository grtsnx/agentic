ANTHROPIC_API_KEY=
INSFORGE_API_KEY=                        # ROTATE THE ONE EXPOSED IN CHAT
INSFORGE_API_BASE_URL=https://insforge.blydr.ai
COOLIFY_API_TOKEN=
COOLIFY_MCP_URL=https://cloud2.blydr.ai/mcp
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=                          # optional — free stock photos + videos; used as fallback when Unsplash/Higgsfield keys are missing
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
R2_ACCOUNT_ID=
RESEND_API_KEY=
EMAIL_DOMAIN=                            # verified Resend sending domain, e.g. example.com (used as {custom}@EMAIL_DOMAIN)
STRIPE_SECRET_KEY=                       # optional — payment provider, skipped if missing
LEMONSQUEEZY_API_KEY=                     # optional — payment provider, skipped if missing
PADDLE_API_KEY=                          # optional — payment provider, skipped if missing
PAYSTACK_SECRET_KEY=                     # optional — payment provider, skipped if missing
PAYPAL_CLIENT_SECRET=                    # optional — payment provider, skipped if missing
HIGGSFIELD_API_KEY=                      # optional — skip video agent if missing
REFERO_API_KEY=                          # optional — Refero Pro bearer token; enables design-research MCP on Design/Research agents
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
ANTHROPIC_ENVIRONMENT_ID=                # optional — auto-created on first `bun run setup:pipeline` and written back here
ANTHROPIC_VAULT_ID=                      # optional — auto-created on first `bun run setup:pipeline` and written back here
ANTHROPIC_MEMORY_STORE_ID=               # optional — auto-created on first `bun run setup:pipeline`; runtime app attaches it to sessions for persona + memory
